# Campaign Ranker Engine 配置

# LLM 配置（OpenAI 格式）
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# 评审引擎参数
JUDGE_TEMPERATURE=0.3
PANEL_TEMPERATURE=0.4
MAX_CAMPAIGNS=6

# Market-Making 对决模式（实验性，默认关闭）
USE_MARKET_JUDGE=false

# Flask
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
SECRET_KEY=replace-with-a-random-string

# 登录用户表（格式: username:password:display_name:role,...）
# 示例:
# MOODY_USERS=admin:StrongPassword123:Admin:admin,analyst:StrongPassword123:Analyst:user
MOODY_USERS=
